rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isAdmin() { return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Users Collection
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string &&
               data.role in ['admin', 'user'] &&
               data.createdAt is timestamp;
      }
      
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && 
                    (isAdmin() || incoming().role == existing().role); // Users can't change their own role
    }

    // Tasks Collection
    match /tasks/{taskId} {
      function isValidTask(data) {
        return data.title is string && data.title.size() <= 200 &&
               data.status in ['open', 'assigned', 'completed'] &&
               data.creatorId == request.auth.uid &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidTask(incoming());
      allow update: if isAdmin() || (isSignedIn() && (
        // Assignee can mark as completed
        (incoming().status == 'completed' && existing().assigneeId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status']))
      ));
      allow delete: if isAdmin();
    }

    // Donations Collection
    match /donations/{donationId} {
      function isValidDonation(data) {
        return data.userId == request.auth.uid &&
               data.amount > 0 &&
               data.transactionId is string &&
               data.status == 'pending' &&
               data.createdAt == request.time;
      }

      allow read: if isOwner(existing().userId) || isAdmin();
      allow create: if isSignedIn() && isValidDonation(incoming());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    // Services Collection
    match /services/{serviceId} {
      function isValidService(data) {
        return data.providerId == request.auth.uid &&
               data.title is string &&
               data.status == 'pending' &&
               data.createdAt == request.time;
      }

      allow read: if (isSignedIn() && (existing().status == 'approved' || isOwner(existing().providerId) || isAdmin()));
      allow create: if isSignedIn() && isValidService(incoming());
      allow update: if isAdmin() || (isOwner(existing().providerId) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'category', 'priceRange']));
    }

    // Posts Collection
    match /posts/{postId} {
      function isValidPost(data) {
        return data.userId == request.auth.uid &&
               data.content is string &&
               data.type in ['general', 'urgent'] &&
               data.createdAt == request.time;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if isOwner(existing().userId) || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['likes']));
      allow delete: if isOwner(existing().userId) || isAdmin();
    }

    // Applications Collection
    match /applications/{applicationId} {
      function isValidApplication(data) {
        return data.volunteerId == request.auth.uid &&
               data.status == 'pending' &&
               data.createdAt == request.time;
      }

      allow read: if isOwner(existing().volunteerId) || isAdmin();
      allow create: if isSignedIn() && isValidApplication(incoming());
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

    // Notifications Collection
    match /notifications/{notificationId} {
      allow read: if isOwner(existing().userId);
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin(); // Only system/admin can create notifications
    }
  }
}
