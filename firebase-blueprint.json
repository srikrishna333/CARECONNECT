{
  "entities": {
    "User": {
      "title": "User",
      "description": "Application user profile with role and community data",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "skills": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "availability": { "type": "string" },
        "servicesOffered": { "type": "array", "items": { "type": "string" } },
        "points": { "type": "number" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "Task": {
      "title": "Task",
      "description": "Community task or volunteer opportunity",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "skillsRequired": { "type": "array", "items": { "type": "string" } },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "assigned", "completed"] },
        "creatorId": { "type": "string" },
        "assigneeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "status", "creatorId", "createdAt"]
    },
    "Donation": {
      "title": "Donation",
      "description": "User donation record via QR",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "verified", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "transactionId", "status", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "description": "Local service offered by a user in the marketplace",
      "type": "object",
      "properties": {
        "providerId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "priceRange": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["providerId", "title", "category", "status", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "Community feed post",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "content": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["general", "urgent"] },
        "likes": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "content", "type", "createdAt"]
    },
    "Application": {
      "title": "Application",
      "description": "Volunteer application for a task",
      "type": "object",
      "properties": {
        "taskId": { "type": "string" },
        "volunteerId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["taskId", "volunteerId", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/tasks/{taskId}": {
      "schema": "Task",
      "description": "Volunteer tasks"
    },
    "/donations/{donationId}": {
      "schema": "Donation",
      "description": "Donation records"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Service marketplace listings"
    },
    "/posts/{postId}": {
      "schema": "Post",
      "description": "Community feed posts"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Task applications"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
